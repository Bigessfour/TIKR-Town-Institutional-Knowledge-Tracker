@inherits LayoutComponentBase
@using Microsoft.AspNetCore.Components.Authorization
@inject AuthSettings Auth
@inject IAuthSessionService AuthSession
@inject NavigationManager Navigation
@inject AuthenticationStateProvider AuthStateProvider

<div class="tikr-layout">
    <nav class="tikr-sidebar">
        <div class="tikr-brand">
            <h1>TIKR</h1>
            <p>The Town Clerk's Second Brain</p>
        </div>
        <ul class="tikr-nav">
            <li><NavLink href="/" Match="NavLinkMatch.All">Dashboard</NavLink></li>
            <li><NavLink href="/calendar">Calendar</NavLink></li>
            <li><NavLink href="/requirements">Requirements</NavLink></li>
            <li><NavLink href="/documents">Documents</NavLink></li>
            <li><NavLink href="/assistant">AI Assistant</NavLink></li>
            <li><NavLink href="/vault">Knowledge Vault</NavLink></li>
            <li><NavLink href="/settings">Settings</NavLink></li>
            @if (Auth.IsEnabled)
            {
                <AuthorizeView Roles="@TikrRoles.Admin">
                    <li><NavLink href="/settings/users">Users</NavLink></li>
                </AuthorizeView>
            }
        </ul>
        @if (Auth.IsEnabled)
        {
            <div class="tikr-user-bar">
                <AuthorizeView>
                    <Authorized>
                        <span class="tikr-user-email">@context.User.Identity?.Name</span>
                        <button type="button" class="tikr-logout" @onclick="LogoutAsync">Sign out</button>
                        <NavLink href="/account" class="tikr-account-link">Account</NavLink>
                    </Authorized>
                </AuthorizeView>
            </div>
        }
    </nav>
    <main class="tikr-main">
        @Body
    </main>
</div>

<div id="blazor-error-ui" data-nosnippet>
    An unhandled error has occurred.
    <a href="." class="reload">Reload</a>
    <span class="dismiss">🗙</span>
</div>

@code {
    private async Task LogoutAsync()
    {
        await AuthSession.LogoutAsync();
        Navigation.NavigateTo("/login", forceLoad: true);
    }
}
