@page "/assistant"
@rendermode InteractiveServer
@implements IDisposable
@inject IChatClient ChatClient
@inject TikrApiClient Api
@inject ColoradoResourceCatalog ResourceCatalog
@using Markdig
@using Microsoft.Extensions.AI
@using TIKR.Web.Components.Shared

<div class="page-header">
    <div class="page-header-main">
        <h2>AI Assistant</h2>
        <p>Local Ollama for everyday questions; Grok for advanced reasoning when enabled.</p>
    </div>
    <PageHelp HelpText="Ask questions in plain English. Your data stays local unless you choose Ask Advanced AI." />
</div>

@if (!string.IsNullOrEmpty(_contextSummary))
{
    <SfCard CssClass="mb-3">
        <CardHeader Title="Clerk context" />
        <CardContent>
            <p class="mb-0" style="white-space: pre-wrap">@_contextSummary</p>
        </CardContent>
    </SfCard>
}

<div class="assistant-container">
    <SfAIAssistView @ref="_assistView"
                    ID="tikrAssistant"
                    Prompt="What should I be working on this week?"
                    PromptPlaceholder="Ask about deadlines, documents, or municipal procedures..."
                    EnableStreaming="true"
                    Width="100%"
                    Height="100%"
                    PromptRequested="OnPromptRequested"
                    ResponseStopped="OnResponseStopped">
    </SfAIAssistView>
</div>

<div class="mt-3">
    <SfButton IsPrimary="false" Content="Ask Advanced AI (Grok)" OnClick="AskAdvancedAsync"></SfButton>
    @if (!string.IsNullOrEmpty(_advancedNote))
    {
        <p class="mt-2 text-muted">@_advancedNote</p>
    }
</div>

@if (!string.IsNullOrEmpty(_advancedAnswer))
{
    <SfCard CssClass="mt-3">
        <CardHeader Title="Advanced AI (Grok)" />
        <CardContent>
            <div>@((MarkupString)_advancedAnswer)</div>
        </CardContent>
    </SfCard>
}

<style>
    .assistant-container {
        height: 520px;
        border: 1px solid #dee2e6;
        border-radius: 8px;
        overflow: hidden;
        background: #fff;
    }
</style>

@code {
    private SfAIAssistView? _assistView;
    private string _contextSummary = "";
    private string _advancedNote = "";
    private string _advancedAnswer = "";
    private string? _lastPrompt;
    private CancellationTokenSource? _streamingCts;

    private string SystemPrompt => AssistantPromptBuilder.BuildSystemPrompt(ResourceCatalog);

    protected override async Task OnInitializedAsync()
    {
        try
        {
            var priorities = await Api.GetDashboardPrioritiesAsync();
            if (priorities.Count > 0)
                _contextSummary = AssistantPromptBuilder.FormatDeadlineContext(priorities);
        }
        catch
        {
            _contextSummary = "Unable to load deadline context from API.";
        }
    }

    private async Task OnPromptRequested(AssistViewPromptRequestedEventArgs args)
    {
        _lastPrompt = args.Prompt;
        // Dispose the previous streaming CTS before allocating a new one so we
        // don't leak CancellationTokenSource instances across chat turns in a
        // long-running Blazor Server circuit.
        _streamingCts?.Cancel();
        _streamingCts?.Dispose();
        _streamingCts = new CancellationTokenSource();
        var token = _streamingCts.Token;

        args.Response = "<div>";
        var markdownBuilder = new System.Text.StringBuilder();

        try
        {
            // Phase 9 RAG: pull top-K semantically relevant docs and prepend their snippets.
            // Best-effort: if Ollama embeddings are unavailable, response is empty and we fall through.
            string? docContext = null;
            try
            {
                var search = await Api.SemanticSearchDocumentsAsync(args.Prompt, topK: 3);
                if (search is { Hits.Count: > 0 })
                {
                    docContext = string.Join("\n", search.Hits.Select(h =>
                        $"- {h.FileName}" +
                        (string.IsNullOrWhiteSpace(h.SuggestedFolder) ? "" : $" [{h.SuggestedFolder}]") +
                        (string.IsNullOrWhiteSpace(h.Snippet) ? "" : $": {h.Snippet}")));
                }
            }
            catch
            {
                docContext = null;
            }

            string? vaultContext = null;
            try
            {
                var vault = await Api.SemanticSearchKnowledgeAsync(args.Prompt, topK: 3);
                if (vault is { Hits.Count: > 0 })
                {
                    vaultContext = string.Join("\n", vault.Hits.Select(h =>
                        $"- {h.Title} [{h.Category}]" +
                        (string.IsNullOrWhiteSpace(h.Snippet) ? "" : $": {h.Snippet}")));
                }
            }
            catch
            {
                vaultContext = null;
            }

            var contextBlocks = new List<string>();
            if (!string.IsNullOrWhiteSpace(_contextSummary))
                contextBlocks.Add($"Upcoming priorities:\n{_contextSummary}");
            if (!string.IsNullOrWhiteSpace(docContext))
                contextBlocks.Add($"Relevant documents:\n{docContext}");
            if (!string.IsNullOrWhiteSpace(vaultContext))
                contextBlocks.Add($"Relevant institutional knowledge:\n{vaultContext}");

            var userMessage = contextBlocks.Count == 0
                ? args.Prompt
                : string.Join("\n\n", contextBlocks) + $"\n\nQuestion: {args.Prompt}";

            var messages = new List<Microsoft.Extensions.AI.ChatMessage>
            {
                new(Microsoft.Extensions.AI.ChatRole.System, SystemPrompt),
                new(Microsoft.Extensions.AI.ChatRole.User, userMessage)
            };

            await foreach (var update in ChatClient.GetStreamingResponseAsync(messages, cancellationToken: token))
            {
                if (string.IsNullOrEmpty(update.Text))
                    continue;

                markdownBuilder.Append(update.Text);
                var html = Markdown.ToHtml(markdownBuilder.ToString());
                await _assistView!.UpdateResponseAsync(html);
            }
        }
        catch (OperationCanceledException)
        {
            await _assistView!.UpdateResponseAsync("<p><em>Response stopped.</em></p>");
        }
        catch (Exception ex)
        {
            await _assistView!.UpdateResponseAsync($"<p class='text-danger'>Local AI unavailable: {ex.Message}. Is Ollama running?</p>");
        }

        await _assistView!.UpdateResponseAsync("</div>");
    }

    private void OnResponseStopped(ResponseStoppedEventArgs args) =>
        _streamingCts?.Cancel();

    private async Task AskAdvancedAsync()
    {
        if (string.IsNullOrWhiteSpace(_lastPrompt))
        {
            _advancedNote = "Send a message in the chat first, then click Ask Advanced AI.";
            StateHasChanged();
            return;
        }

        var result = await Api.AskAdvancedAsync(_lastPrompt, _contextSummary);
        if (result is null)
        {
            _advancedNote = "Advanced AI unavailable. Enable USE_GROK=true and GROK_API_KEY on the API.";
            StateHasChanged();
            return;
        }

        _advancedNote = result.UsedGrok
            ? "Grok response shown below."
            : "Advanced AI response shown below.";

        _advancedAnswer = Markdown.ToHtml(result.Answer);
        StateHasChanged();
    }

    public void Dispose()
    {
        _streamingCts?.Cancel();
        _streamingCts?.Dispose();
        _streamingCts = null;
    }
}
