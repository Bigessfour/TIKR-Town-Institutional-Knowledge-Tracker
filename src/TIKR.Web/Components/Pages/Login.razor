@page "/login"
@rendermode InteractiveServer
@attribute [Microsoft.AspNetCore.Authorization.AllowAnonymous]
@inject AuthSettings Auth
@inject IAuthSessionService AuthSession
@inject NavigationManager Navigation

<div class="login-page">
    <SfCard CssClass="login-card">
        <CardHeader Title="Sign in to TIKR" />
        <CardContent>
            @if (!Auth.IsEnabled)
            {
                <p>Authentication is not enabled for this deployment.</p>
            }
            else
            {
                @if (!string.IsNullOrWhiteSpace(_error))
                {
                    <div class="login-error">@_error</div>
                }

                <EditForm Model="_model" OnValidSubmit="HandleLoginAsync">
                    <DataAnnotationsValidator />
                    <SfDataForm Model="_model" ColumnCount="1" Width="100%">
                        <FormItems>
                            <FormItem Field="@nameof(LoginFormModel.Email)" LabelText="Email" />
                            <FormItem Field="@nameof(LoginFormModel.Password)" LabelText="Password">
                                <Template>
                                    <SfTextBox @bind-Value="_model.Password" Type="InputType.Password" Placeholder="Password" />
                                </Template>
                            </FormItem>
                        </FormItems>
                    </SfDataForm>
                    <div class="mt-3">
                        <SfButton Type="ButtonType.Submit" CssClass="e-primary" IsPrimary="true" Disabled="_busy">
                            @(_busy ? "Signing in..." : "Sign in")
                        </SfButton>
                    </div>
                </EditForm>
            }
        </CardContent>
    </SfCard>
</div>

@code {
    private readonly LoginFormModel _model = new();
    private string? _error;
    private bool _busy;
    private string _returnUrl = "/";

    protected override void OnInitialized()
    {
        if (!Auth.IsEnabled)
        {
            Navigation.NavigateTo("/");
            return;
        }

        var uri = Navigation.ToAbsoluteUri(Navigation.Uri);
        if (Microsoft.AspNetCore.WebUtilities.QueryHelpers.ParseQuery(uri.Query).TryGetValue("returnUrl", out var value))
            _returnUrl = value.FirstOrDefault() ?? "/";
    }

    private async Task HandleLoginAsync()
    {
        _busy = true;
        _error = null;
        try
        {
            var result = await AuthSession.LoginAsync(new TIKR.Shared.DTOs.LoginRequest(_model.Email, _model.Password));
            if (result is null)
            {
                _error = "Invalid email or password.";
                return;
            }

            Navigation.NavigateTo(_returnUrl, forceLoad: true);
        }
        finally
        {
            _busy = false;
        }
    }
}
