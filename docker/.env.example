# ======================
# TIKR - Secrets Template
# Copy to docker/.env and fill in real values.
# Never commit docker/.env
# ======================

# === Syncfusion (Required) ===
SYNCFUSION_LICENSE_KEY=your_syncfusion_license_key_here

# === AI Configuration ===
USE_GROK=false
GROK_API_KEY=xai-your_grok_api_key_here

# === Storage & Database ===
FILE_STORAGE_PATH=/data/documents
DATABASE_PROVIDER=Sqlite
ConnectionStrings__Default=Data Source=/data/tikr.db

# === General ===
ASPNETCORE_ENVIRONMENT=Production
TIKR_API_URL=http://tikr-api:8080
# Footer + Settings local storage label (Phase 0)
TIKR_TOWN_NAME=Wiley
TIKR_STORAGE_LABEL=Synology NAS
# Agent scan storage (Phase 10C). Optional AES-256-GCM key — generate: openssl rand -base64 32
# TIKR_AGENT_STORAGE_KEY=
USE_SYNCFUSION_AGENT_TOOLS=false
# When true (requires USE_SYNCFUSION_AGENT_TOOLS=true + Ollama), Ollama picks Syncfusion tools via MEAI function calling.
USE_SYNCFUSION_AGENT_ORCHESTRATION=false
OLLAMA_HOST=http://ollama:11434

# === Multi-user auth (optional — set all three to enable login) ===
# See README "Optional multi-user auth" for example values.
# TIKR_ADMIN_EMAIL=
# TIKR_ADMIN_PASSWORD=
# TIKR_JWT_SIGNING_KEY=
# TIKR_AUTH_ENABLED=true
