# ======================
# TIKR - Secrets Template
# Copy to docker/.env and fill in real values.
# Never commit docker/.env
# ======================

# === Syncfusion (Required) ===
SYNCFUSION_LICENSE_KEY=your_syncfusion_license_key_here

# === AI Configuration ===
USE_GROK=false
GROK_API_KEY=xai-your_grok_api_key_here
# xAI model (grok-2-latest is deprecated; grok-3 works with current xAI keys)
GROK_MODEL=grok-3
OLLAMA_HOST=http://ollama:11434
OLLAMA_CHAT_MODEL=llama3.2:3b

# === Storage & Database ===
FILE_STORAGE_PATH=/data/documents
DATABASE_PROVIDER=Sqlite
ConnectionStrings__Default=Data Source=/data/tikr.db

# === General ===
ASPNETCORE_ENVIRONMENT=Production
TIKR_API_URL=http://tikr-api:8080
# Browser-reachable API URL for PDF preview/download when Web runs on a different host/port (Docker default)
TIKR_PUBLIC_API_URL=http://localhost:5000
# Host port mapped to tikr-api (set 5001 on macOS if AirPlay binds :5000)
TIKR_API_HOST_PORT=5000
TIKR_WEB_HOST_PORT=8080
TIKR_OLLAMA_HOST_PORT=11434

# === Production (Synology / GHCR images) ===
TIKR_VERSION=latest
TIKR_DATA_PATH=/volume1/tikr/data
TIKR_OLLAMA_PATH=/volume1/tikr/ollama

# === General ===
TIKR_TOWN_NAME=Wiley
TIKR_STORAGE_LABEL=Synology NAS

# === Document agent (Phase 10C) ===
# Agent scan storage (optional AES-256-GCM key — generate: openssl rand -base64 32)
# TIKR_AGENT_STORAGE_KEY=
USE_SYNCFUSION_AGENT_TOOLS=false
# When true (requires USE_SYNCFUSION_AGENT_TOOLS=true + Ollama), Ollama picks Syncfusion tools via MEAI function calling.
USE_SYNCFUSION_AGENT_ORCHESTRATION=false

# === Multi-user auth (optional — set all three to enable login) ===
# See README "Optional multi-user auth" for example values.
# TIKR_ADMIN_EMAIL=
# TIKR_ADMIN_PASSWORD=
# TIKR_JWT_SIGNING_KEY=
# TIKR_AUTH_ENABLED=true
