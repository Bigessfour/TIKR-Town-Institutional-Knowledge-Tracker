{
  "mcpServers": {
    "sf-blazor-mcp": {
      "command": "npx",
      "args": ["-y", "@syncfusion/blazor-assistant@latest"],
      "env": {
        "Syncfusion_API_Key": "${env:SYNCFUSION_API_KEY}"
      }
    },
    "microsoft-learn": {
      "url": "https://learn.microsoft.com/api/mcp"
    },
    "ollama": {
      "command": "npx",
      "args": ["-y", "ollama-mcp"],
      "env": {
        "OLLAMA_HOST": "http://localhost:11434"
      }
    },
    "tikr-rag-mcp": {
      "command": "/absolute/path/to/repo/.venv/bin/python3",
      "args": ["/absolute/path/to/repo/scripts/tikr_rag_mcp.py"],
      "env": {
        "OLLAMA_HOST": "http://localhost:11434"
      }
    }
  }
}
